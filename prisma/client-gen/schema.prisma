generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Instructor {
  id               Int    @id @default(autoincrement())
  name             String
  title            String
  bio              String
  avatarUrl        String
  experience       String
  projectsDone     String
  studentsCount    String
  satisfactionRate String
}

model Course {
  id          Int    @id @default(autoincrement())
  type        String // "free" | "pro"
  name        String
  description String
  modules     String // JSON array of module names
  order       Int    @default(0)
}

model Project {
  id           Int    @id @default(autoincrement())
  studentName  String
  tool         String // "After Effects" | "Premiere"
  thumbnailUrl String
  videoUrl     String
  order        Int    @default(0)
}

model Feature {
  id          Int    @id @default(autoincrement())
  icon        String
  title       String
  description String
  order       Int    @default(0)
}

model ContactInfo {
  id       Int    @id @default(autoincrement())
  phone    String
  email    String
  facebook String
  address  String
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String?
  createdAt DateTime @default(now())
}
